# Ambiente
AMBIENTE=local

# Prefect
PREFECT_PORT=4200

# MinIO
PORT_API=9000
PORT_FRONT=9001
MINIO_ENDPOINT=minio:9000
MINIO_LOGIN=change-me
MINIO_PASSWORD=change-me
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me

# Catálogo Iceberg REST (Lakekeeper)
ICEBERG_CATALOG_ENDPOINT=http://lakekeeper:8181/catalog
ICEBERG_WAREHOUSE=prefect
ICEBERG_CATALOG_NAME=lakehouse
LAKEKEEPER_PORT=8181
LAKEKEEPER_DB_PASSWORD=change-me
# Gere um valor aleatório forte e persistente. Não altere depois de armazenar segredos.
LAKEKEEPER_ENCRYPTION_KEY=change-me-with-at-least-32-random-characters

# Opcional para catálogos Iceberg protegidos por bearer token.
# ICEBERG_TOKEN=
