{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "camara_deputados_despesas",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "subProcess": false,
      // "program": "${workspaceFolder}/pipelines/camara_deputados/despesas/orquestrador.py",
      "module": "pipelines.camara_deputados.despesas.orquestrador",
      "cwd": "${workspaceFolder}",
      // "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env"
    },

    {
      "name": "camara_deputados_deputados",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "subProcess": false,
      // "program": "${workspaceFolder}/pipelines/camara_deputados/despesas/orquestrador.py",
      "module": "pipelines.camara_deputados.deputados.orquestrador",
      "cwd": "${workspaceFolder}",
      // "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "MINIO_ENDPOINT": "localhost:9000",
        "ICEBERG_CATALOG_ENDPOINT": "http://localhost:8181/catalog",
        "PREFECT_API_URL": "http://127.0.0.1:4200/api"
      }
    }


  ]
}
